# ─────────────────────────────────────────────
#  Discord Welcome Bot — Environment Variables
# ─────────────────────────────────────────────

# Your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Your bot's Application/Client ID (found in the Developer Portal)
CLIENT_ID=your_client_id_here

# (Optional) Restrict slash command deployment to a single guild during testing.
# Remove or leave blank to deploy commands globally (takes ~1 hour to propagate).
GUILD_ID=your_guild_id_here
